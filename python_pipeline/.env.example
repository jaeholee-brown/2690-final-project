OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com
XAI_BASE_URL=https://api.x.ai/v1

PRIMARY_OPENAI_MODEL=gpt-5.4-mini
PRIMARY_ANTHROPIC_MODEL=claude-haiku-4-5
PRIMARY_GEMINI_MODEL=gemini-3-flash-preview
PRIMARY_OPENAI_REASONING=low
PRIMARY_GEMINI_REASONING=low

ESCALATION_OPENAI_MODEL=gpt-5.4
ESCALATION_XAI_MODEL=grok-4.20-0309-reasoning
ESCALATION_ANTHROPIC_MODEL=claude-sonnet-4-6
ESCALATION_OPENAI_REASONING=medium

MAX_RETRIES=8
RETRY_BASE_SECONDS=1
RETRY_MAX_SECONDS=60
CACHE_PATH=.cache/meta_screen.sqlite3
MAX_IN_FLIGHT_RECORDS=32
RATE_LIMIT_UTILIZATION=0.8
